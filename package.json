{
  "name": "lwcode",
  "version": "1.0.0",
  "description": "LeekWars Code — LeekScript AI programming assistant",
  "type": "module",
  "bin": {
    "lwcode": "./dist/lwcode"
  },
  "scripts": {
    "build": "bun build src/entrypoints/cli.tsx --compile --outfile dist/lwcode --define 'MACRO.VERSION=\"1.0.0\"' --define 'MACRO.PACKAGE_URL=\"lwcode\"' --define 'MACRO.ISSUES_EXPLAINER=\"report at https://github.com/tankyx/claude-code/issues\"' --define 'process.env.USER_TYPE=\"external\"'",
    "build:bundle": "bun build src/entrypoints/cli.tsx --outfile dist/lwcode.js --define 'MACRO.VERSION=\"1.0.0\"' --define 'MACRO.PACKAGE_URL=\"lwcode\"' --define 'MACRO.ISSUES_EXPLAINER=\"report at https://github.com/tankyx/claude-code/issues\"' --define 'process.env.USER_TYPE=\"external\"'",
    "start": "bun src/entrypoints/cli.tsx"
  },
  "dependencies": {
    "@alcalzone/ansi-tokenize": "^0.1.0",
    "@anthropic-ai/sdk": "^0.52.0",
    "@commander-js/extra-typings": "^13.1.0",
    "@growthbook/growthbook": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.57.0",
    "@opentelemetry/core": "^1.30.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.57.0",
    "@opentelemetry/sdk-metrics": "^1.30.0",
    "@opentelemetry/sdk-trace-base": "^1.30.0",
    "@opentelemetry/semantic-conventions": "^1.30.0",
    "ajv": "^8.17.0",
    "asciichart": "^1.5.25",
    "auto-bind": "^5.0.0",
    "axios": "^1.7.0",
    "bidi-js": "^1.0.3",
    "chalk": "^5.3.0",
    "chokidar": "^4.0.0",
    "cli-boxes": "^3.0.0",
    "cli-highlight": "^2.1.11",
    "code-excerpt": "^4.0.0",
    "commander": "13.1.0",
    "diff": "^7.0.0",
    "emoji-regex": "^10.4.0",
    "env-paths": "^3.0.0",
    "execa": "^9.5.0",
    "figures": "^6.1.0",
    "fuse.js": "^7.0.0",
